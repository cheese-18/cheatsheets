<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Instant Sum Calculator</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f2f5f9;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.card{
    width:350px;
    background:#fff;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,.15);
}

.card h2{
    text-align:center;
    margin-bottom:20px;
    color:#333;
}

input{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:2px solid #ddd;
    border-radius:10px;
    font-size:18px;
    text-align:center;
    transition:.3s;
}

input:focus{
    border-color:#4CAF50;
    outline:none;
}

.result{
    margin-top:20px;
    text-align:center;
    background:#4CAF50;
    color:white;
    padding:15px;
    border-radius:10px;
}

.result h1{
    margin-top:8px;
    font-size:40px;
}
</style>
</head>
<body>

<div class="card">
    <h2>Instant Sum Calculator</h2>

    <input type="number" id="num1" placeholder="Enter first number">
    <input type="number" id="num2" placeholder="Enter second number">

    <div class="result">
        <p>Sum</p>
        <h1 id="answer">0</h1>
    </div>
</div>

<script>
const num1 = document.getElementById("num1");
const num2 = document.getElementById("num2");
const answer = document.getElementById("answer");

function calculate(){
    const a = parseFloat(num1.value) || 0;
    const b = parseFloat(num2.value) || 0;
    answer.textContent = a + b;
}

num1.addEventListener("input", calculate);
num2.addEventListener("input", calculate);
</script>

</body>
</html>



<div class="max-w-4xl mx-auto bg-white rounded-3xl shadow-xl p-8">

    <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-slate-800">
            Arithmetic Calculator
        </h1>
        <p class="text-gray-500 mt-2">
            Enter two numbers to see all arithmetic operations instantly.
        </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">

        <!-- Inputs -->
        <div class="space-y-5">

            <div>
                <label class="font-semibold text-gray-700">First Number</label>
                <input
                    id="num1"
                    type="number"
                    placeholder="Enter first number"
                    class="mt-2 w-full border-2 border-gray-200 rounded-xl px-4 py-3 focus:border-emerald-500 focus:ring-emerald-500">
            </div>

            <div>
                <label class="font-semibold text-gray-700">Second Number</label>
                <input
                    id="num2"
                    type="number"
                    placeholder="Enter second number"
                    class="mt-2 w-full border-2 border-gray-200 rounded-xl px-4 py-3 focus:border-emerald-500 focus:ring-emerald-500">
            </div>

        </div>

        <!-- Results -->
        <div class="grid grid-cols-2 gap-4">

            <div class="bg-green-500 text-white rounded-xl p-5 text-center">
                <h3 class="text-lg font-semibold">Addition</h3>
                <p id="add" class="text-3xl font-bold mt-2">0</p>
            </div>

            <div class="bg-red-500 text-white rounded-xl p-5 text-center">
                <h3 class="text-lg font-semibold">Subtraction</h3>
                <p id="subtract" class="text-3xl font-bold mt-2">0</p>
            </div>

            <div class="bg-blue-500 text-white rounded-xl p-5 text-center">
                <h3 class="text-lg font-semibold">Multiplication</h3>
                <p id="multiply" class="text-3xl font-bold mt-2">0</p>
            </div>

            <div class="bg-purple-500 text-white rounded-xl p-5 text-center">
                <h3 class="text-lg font-semibold">Division</h3>
                <p id="divide" class="text-3xl font-bold mt-2">0</p>
            </div>

        </div>

    </div>

</div>




const num1 = document.getElementById("num1");
const num2 = document.getElementById("num2");

function calculate() {

    const a = parseFloat(num1.value) || 0;
    const b = parseFloat(num2.value) || 0;

    document.getElementById("add").textContent = a + b;
    document.getElementById("subtract").textContent = a - b;
    document.getElementById("multiply").textContent = a * b;

    document.getElementById("divide").textContent =
        b !== 0 ? (a / b).toFixed(2) : "Undefined";
}

num1.addEventListener("input", calculate);
num2.addEventListener("input", calculate);

