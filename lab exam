<template>
  <div class="min-h-screen bg-gray-100 p-8">

    <!-- Title -->
    <h1 class="text-4xl font-bold text-center mb-8">
      Vue + Tailwind Cheat Sheet
    </h1>

    <!-- Variables -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">Variables</h2>

      <p>Name: {{ name }}</p>
      <p>Age: {{ age }}</p>

      <button
        @click="age++"
        class="mt-3 bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded"
      >
        Increase Age
      </button>
    </section>

    <!-- v-model -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">v-model</h2>

      <input
        v-model="name"
        class="border rounded w-full p-2"
        placeholder="Enter your name"
      >

      <p class="mt-3">
        Hello {{ name }}
      </p>
    </section>

    <!-- v-if -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">v-if</h2>

      <button
        @click="loggedIn = !loggedIn"
        class="bg-blue-600 text-white px-4 py-2 rounded"
      >
        Toggle Login
      </button>

      <p v-if="loggedIn" class="text-green-600 mt-3">
        Welcome User!
      </p>

      <p v-else class="text-red-600 mt-3">
        Please Login
      </p>
    </section>

    <!-- v-show -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">v-show</h2>

      <button
        @click="show = !show"
        class="bg-purple-600 text-white px-4 py-2 rounded"
      >
        Toggle
      </button>

      <p v-show="show" class="mt-3">
        I am visible!
      </p>
    </section>

    <!-- v-for -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">v-for</h2>

      <ul>
        <li
          v-for="student in students"
          :key="student.id"
          class="border-b py-2"
        >
          {{ student.id }} - {{ student.name }}
        </li>
      </ul>
    </section>

    <!-- Computed -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">Computed</h2>

      <input
        v-model="firstName"
        class="border p-2 rounded mb-2 w-full"
        placeholder="First Name"
      >

      <input
        v-model="lastName"
        class="border p-2 rounded w-full"
        placeholder="Last Name"
      >

      <p class="mt-3">
        Full Name: {{ fullName }}
      </p>
    </section>

    <!-- Object -->
    <section class="bg-white p-6 rounded-xl shadow mb-6">
      <h2 class="text-2xl font-bold mb-4">Object</h2>

      <p>{{ user.name }}</p>
      <p>{{ user.course }}</p>
    </section>

    <!-- Tailwind Examples -->
    <section class="bg-white p-6 rounded-xl shadow">

      <h2 class="text-2xl font-bold mb-6">
        Tailwind Examples
      </h2>

      <!-- Flex -->
      <div class="flex gap-4 mb-6">
        <div class="bg-red-500 text-white p-4 rounded">Flex 1</div>
        <div class="bg-green-500 text-white p-4 rounded">Flex 2</div>
        <div class="bg-blue-500 text-white p-4 rounded">Flex 3</div>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-yellow-300 p-5 rounded">Grid 1</div>
        <div class="bg-yellow-300 p-5 rounded">Grid 2</div>
        <div class="bg-yellow-300 p-5 rounded">Grid 3</div>
      </div>

      <!-- Button -->
      <button
        class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded transition duration-300"
      >
        Tailwind Button
      </button>

    </section>

  </div>
</template>

<script setup>
import { ref, computed, watch, onMounted } from "vue";

// Variables
const name = ref("Rean");
const age = ref(18);

// v-if
const loggedIn = ref(false);

// v-show
const show = ref(true);

// Object
const user = ref({
  name: "John Doe",
  course: "STEM"
});

// List
const students = ref([
  { id: 1, name: "John" },
  { id: 2, name: "Jane" },
  { id: 3, name: "Michael" }
]);

// Computed
const firstName = ref("Rean");
const lastName = ref("Coopera");

const fullName = computed(() => {
  return firstName.value + " " + lastName.value;
});

// Watch
watch(name, (newValue) => {
  console.log("Name changed:", newValue);
});

// Lifecycle
onMounted(() => {
  console.log("Component Loaded");
});

// Methods
function save() {
  alert("Saved!");
}
</script>

