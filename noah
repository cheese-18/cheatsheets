<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vue Mood Counter</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
</head>
<body class="min-h-screen bg-slate-100 flex items-center justify-center">

    <div id="app" class="w-full max-w-lg mx-4">
        <div class="bg-white rounded-2xl shadow-xl border border-slate-200 overflow-hidden">

            <div class="bg-gradient-to-r from-blue-700 to-blue-900 text-white p-8 text-center">
                <h1 class="text-2xl font-bold">
                    {{ message }}
                </h1>
            </div>

            <div class="p-8">
                <div class="text-center">
                    <p class="text-slate-500 uppercase tracking-widest text-sm">
                        Mood Points
                    </p>
                    <h2 class="text-6xl font-extrabold text-slate-800 mt-2">
                        {{ count }}
                    </h2>
                </div>

                <div class="mt-8">
                    <div class="bg-slate-50 border border-slate-200 rounded-xl p-5">
                        <p class="text-sm text-slate-500 uppercase tracking-wide">
                            Current Status
                        </p>
                        <h3 class="text-2xl font-bold text-slate-800 mt-2">
                            {{ status }}
                        </h3>
                    </div>
                </div>

                <div class="grid grid-cols-3 gap-4 mt-8">
                    <button @click="increase" class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition duration-200">
                        Good
                    </button>
                    <button @click="decrease" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-3 rounded-xl transition duration-200">
                        Bad
                    </button>
                    <button @click="reset" class="bg-slate-700 hover:bg-slate-800 text-white font-semibold py-3 rounded-xl transition duration-200">
                        Reset
                    </button>
                </div>
            </div>

        </div>
    </div>

    <script>
        const { createApp, ref } = Vue;

        createApp({
            setup() {
                const count = ref(0);
                const status = ref("Neutral");
                const message = ref("Welcome! Click a button to begin.");

                const increase = () => {
                    count.value++;

                    if (count.value >= 5) {
                        status.value = "Excellent";
                        message.value = "Outstanding! Keep up the great work.";
                    } else if (count.value >= 3) {
                        status.value = "Very Good";
                        message.value = "You're doing really well!";
                    } else if (count.value >= 1) {
                        status.value = "Good";
                        message.value = "Nice! Keep going.";
                    } else if (count.value == 0) {
                        status.value = "Neutral";
                        message.value = "Everything is balanced.";
                    }
                };

                const decrease = () => {
                    count.value--;

                    if (count.value == 0) {
                        status.value = "Neutral";
                        message.value = "Everything is balanced.";
                    } else if (count.value == -1) {
                        status.value = "Sick";
                        message.value = "Take a short rest.";
                    } else if (count.value <= -3 && count.value > -5) {
                        status.value = "Very Sick";
                        message.value = "You should take better care of yourself.";
                    } else if (count.value <= -5) {
                        status.value = "Critical";
                        message.value = "Seek medical attention immediately.";
                    }
                };

                const reset = () => {
                    count.value = 0;
                    status.value = "Neutral";
                    message.value = "Welcome! Click a button to begin.";
                };

                return {
                    count,
                    status,
                    message,
                    increase,
                    decrease,
                    reset
                };
            }
        }).mount("#app");
    </script>

</body>
</html>
